<apex:page renderAs="pdf"
           controller="PaymentReceiptController"
           showHeader="false"
           sidebar="false"
           standardStylesheets="false"
           contentType="application/pdf">

<html>
<head>
<style>
body {
    font-family: Arial, sans-serif;
    font-size: 10px;
    color: #1a1a1a;
    margin: 0;
    padding: 0;
}
table { border-collapse: collapse; }
.label { font-size: 8px; color: #555; }
.section-header {
    font-size: 9px;
    font-weight: bold;
    color: #1740a8;
    border-bottom: 2px solid #1740a8;
    padding-bottom: 3px;
    margin-bottom: 6px;
}
</style>
</head>

<body>

<!-- ERROR MESSAGE -->
<apex:outputPanel rendered="{!NOT(ISBLANK(errorMessage))}">
<table width="100%">
<tr>
<td style="background:#fff0f0;border:2px solid #cc0000;padding:12px;font-size:11px;color:#cc0000;font-weight:bold;">
ERROR: {!errorMessage}
</td>
</tr>
</table>
</apex:outputPanel>

<table width="100%">
<tr>
<td style="padding:10px">
<table width="100%" style="border:2px solid #1740a8">
<tr>
<td style="padding:18px">

<!-- ===== HEADER ===== -->
<table width="100%" style="margin-bottom:10px">
<tr>
<td width="60%">
<table>
<tr>
<td style="padding-right:8px">
<img src="{!URLFOR($Resource.ArrayMinds)}" height="32"/>
</td>
<td>
<div style="font-size:13px;font-weight:bold;color:#1a3a5c">ARRAYMINDS</div>
<div style="font-size:7.5px;color:#555">Partner Portal</div>
</td>
</tr>
</table>
</td>

</tr>
</table>

<!-- ===== BLUE HEADER ===== -->
<table width="100%" style="background:#1740a8;margin-top:4px">
<tr>
<td style="padding:14px 15px">
<div style="font-size:22px;color:white;font-weight:bold">PAYMENT RECEIPT</div>
</td>
<td align="right" style="padding:14px 15px">
<div style="font-size:8px;color:#b8ccf0">Amount Paid</div>
<apex:outputPanel rendered="{!NOT(ISNULL(latestPayment))}">
<div style="font-size:26px;color:white;font-weight:bold">
<apex:outputText value="{0,number,###,##0.00}">
<apex:param value="{!latestPayment.Amount__c}"/>
</apex:outputText>
</div>
</apex:outputPanel>
</td>
</tr>
</table>

<!-- ===== RECEIPT META ===== -->
<table width="100%" style="border:1px solid #d8e4f4;background:#f4f7fd;margin-top:10px">
<tr>
<td style="padding:10px" width="33%">
<div class="label">RECEIPT NO</div>
<apex:outputPanel rendered="{!NOT(ISNULL(latestPayment))}">
<div style="font-size:11px;font-weight:bold">{!latestPayment.Name}</div>
</apex:outputPanel>
</td>
<td style="padding:10px;border-left:1px solid #d0daea" width="33%">
<div class="label">RECEIPT DATE</div>
<apex:outputPanel rendered="{!NOT(ISNULL(latestPayment.Payment_Date__c))}">
<div style="font-size:11px;font-weight:bold">
<apex:outputText value="{0,date,dd MMM yyyy}">
<apex:param value="{!latestPayment.Payment_Date__c}"/>
</apex:outputText>
</div>
</apex:outputPanel>
</td>
<td style="padding:10px;border-left:1px solid #d0daea" width="33%">
<div class="label">PAYMENT STATUS</div>
<apex:outputPanel rendered="{!NOT(ISNULL(latestPayment))}">
<div style="font-size:11px;font-weight:bold;color:#c97000">{!latestPayment.Payment_Status__c}</div>
</apex:outputPanel>
</td>
</tr>
</table>

<!-- ===== ORDER + CUSTOMER ===== -->
<table width="100%" style="margin-top:15px">
<tr>

<!-- ORDER DETAILS -->
<td width="50%" valign="top">
<div class="section-header">ORDER DETAILS</div>
<table width="100%" style="margin-top:4px;font-size:9px">
<tr><td style="padding:3px 0;color:#555">Order Number</td><td style="padding:3px 0"><b>{!orderNumber}</b></td></tr>
<tr><td style="padding:3px 0;color:#555">Payment Mode</td><td style="padding:3px 0"><b>{!latestPayment.Payment_Mode__c}</b></td></tr>
<tr>
<td style="padding:3px 0;color:#555">Order Start Date</td>
<td style="padding:3px 0">
<apex:outputPanel rendered="{!NOT(ISNULL(orderStartDate))}">
<apex:outputText value="{0,date,dd MMM yyyy}"><apex:param value="{!orderStartDate}"/></apex:outputText>
</apex:outputPanel>
</td>
</tr>
<tr><td style="padding:3px 0;color:#555">Currency</td><td style="padding:3px 0">INR (&#8377;)</td></tr>
<tr>
<td style="padding:3px 0;color:#555">Order Total</td>
<td style="padding:3px 0">
<apex:outputText value="{0,number,###,##0.00}"><apex:param value="{!orderTotalAmount}"/></apex:outputText>
</td>
</tr>
<tr>
<td style="padding:3px 0;color:#555">Paid Before</td>
<td style="padding:3px 0">
<apex:outputText value="{0,number,###,##0.00}"><apex:param value="{!amountPaidBeforeThis}"/></apex:outputText>
</td>
</tr>
<tr>
<td style="padding:3px 0;color:#1740a8;font-weight:bold">Balance Due</td>
<td style="padding:3px 0;color:#1740a8;font-weight:bold">
<apex:outputText value="{0,number,###,##0.00}"><apex:param value="{!balanceDue}"/></apex:outputText>
</td>
</tr>
</table>
</td>

<!-- CUSTOMER DETAILS -->
<td width="50%" valign="top" style="padding-left:20px">
<div class="section-header">CUSTOMER DETAILS</div>
<table style="margin-top:4px;font-size:9px">
<tr><td style="padding:3px 0;font-size:12px;font-weight:bold">{!customerName}</td></tr>
<tr><td style="padding:2px 0;color:#555">{!billingStreet}</td></tr>
<tr><td style="padding:2px 0;color:#555">{!billingCity}, {!billingPostalCode}, {!billingCountry}</td></tr>
<tr><td style="padding:2px 0;color:#555">{!customerPhone}</td></tr>
</table>
</td>

</tr>
</table>

<!-- ===== PAYMENT BREAKDOWN ===== -->
<div style="font-size:11px;font-weight:bold;margin-top:20px;margin-bottom:6px">Payment Breakdown</div>
<table width="100%">
<tr style="background:#1740a8;color:white;font-weight:bold;font-size:8px">
<td width="18%" style="padding:7px">PAYMENT NO</td>
<td width="18%" style="padding:7px">DATE</td>
<td width="18%" style="padding:7px">METHOD</td>
<td width="28%" style="padding:7px">REFERENCE</td>
<td width="18%" style="padding:7px" align="right">AMOUNT PAID</td>
</tr>
<tr style="background:#f7f9fd;font-size:9px">
<td style="padding:7px;font-weight:bold">{!latestPayment.Name}</td>
<td style="padding:7px">
<apex:outputText value="{0,date,dd MMM yyyy}"><apex:param value="{!latestPayment.Payment_Date__c}"/></apex:outputText>
</td>
<td style="padding:7px">{!latestPayment.Payment_Mode__c}</td>
<td style="padding:7px">{!latestPayment.Transaction_Id__c}</td>
<td align="right" style="padding:7px">
<apex:outputText value="{0,number,###,##0.00}"><apex:param value="{!latestPayment.Amount__c}"/></apex:outputText>
</td>
</tr>
</table>

<!-- ===== TOTALS SUMMARY ===== -->
<table width="100%" style="margin-top:10px">
<tr>
<td width="55%"></td>
<td width="45%">
<table width="100%" style="font-size:9px">
<tr>
<td style="padding:4px 8px;color:#555">Order Total Amount</td>
<td align="right" style="padding:4px 8px">
<apex:outputText value="{0,number,###,##0.00}"><apex:param value="{!orderTotalAmount}"/></apex:outputText>
</td>
</tr>
<tr>
<td style="padding:4px 8px;color:#555">Total Amount Paid</td>
<td align="right" style="padding:4px 8px">
<apex:outputText value="{0,number,###,##0.00}"><apex:param value="{!amountPaid}"/></apex:outputText>
</td>
</tr>
<tr style="border-top:2px solid #1740a8">
<td style="padding:6px 8px;font-weight:bold;color:#1740a8;font-size:10px">Balance Due</td>
<td align="right" style="padding:6px 8px;font-weight:bold;color:#1740a8;font-size:10px">
<apex:outputText value="{0,number,###,##0.00}"><apex:param value="{!balanceDue}"/></apex:outputText>
</td>
</tr>
</table>
</td>
</tr>
</table>

<!-- ===== AUTHORIZED SIGNATORY ===== -->
<table width="100%" style="margin-top:15px">
<tr>
<td width="60%"></td>
<td width="40%" align="right">
<table style="border:1px dashed #1740a8;padding:10px;width:180px;float:right">
<tr>
<td align="center">
<img src="{!URLFOR($Resource.ArrayMinds)}" height="22"/>
</td>
</tr>
<tr>
<td align="center" style="font-size:7px;color:#999;padding-top:4px">STAMP / SIGNATURE</td>
</tr>
<tr>
<td align="center" style="font-size:8px;font-weight:bold;padding-top:6px">AUTHORIZED SIGNATORY</td>
</tr>
<tr>
<td align="center" style="font-size:7px;color:#555">ARRAYMINDS</td>
</tr>
</table>
</td>
</tr>
</table>

<!-- ===== FOOTER ===== -->
<table width="100%" style="margin-top:20px">
<tr>
<td style="background:#eef3fb;border:1px solid #ccd8ee;padding:10px;font-size:8px;color:#000000">
This is a computer-generated document and does not require a physical signature. For any discrepancies, please contact our accounts department within 24 hours of receipt. Thank you for your business.
</td>
</tr>
</table>

<!-- FOOTER COMPANY INFO -->
<table width="100%" style="margin-top:10px;border-top:1px solid #d0daea">
<tr>
<td align="center" style="padding-top:8px;font-size:12px;font-weight:bold;color:#1a3a5c">ARRAYMINDS</td>
</tr>
<tr>
<td align="center" style="font-size:10px;color:#888">Array Minds Partner Portal | https://www.arrayminds.com</td>
</tr>
</table>

</td>
</tr>
</table>
</td>
</tr>
</table>

</body>
</html>

</apex:page>
