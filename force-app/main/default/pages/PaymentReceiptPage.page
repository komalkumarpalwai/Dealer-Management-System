<apex:page renderAs="pdf"
           controller="PaymentReceiptController"
           showHeader="false"
           sidebar="false"
           standardStylesheets="false"
           contentType="application/pdf">
<html>
<head>
<style>
  body { font-family: Arial, sans-serif; font-size: 10px; color: #1a1a1a; margin: 0; padding: 0; }
</style>
</head>
<body>

<table width="100%" border="0" cellpadding="0" cellspacing="0">
<tr><td style="padding: 10px;">

  <!-- OUTER BORDER WRAPPER -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="border: 2px solid #1740a8; border-radius: 4px;">
  <tr><td style="padding: 16px 28px 14px 28px;">

  <!-- TOP HEADER ROW -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:10px;">
    <tr>
      <td width="50%" style="vertical-align:middle;">
        <table border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td style="vertical-align:middle; padding-right:7px;">
              <img src="{!URLFOR($Resource.ArrayMinds)}" height="26" style="display:block;"/>
            </td>
            <td style="vertical-align:middle;">
              <div style="font-size:12px; font-weight:bold; color:#1a3a5c;">ARRAYMINDS</div>
              <div style="font-size:7.5px; color:#555; margin-top:1px;">Dealer Management System</div>
            </td>
          </tr>
        </table>
      </td>
      <td width="50%" style="text-align:right; vertical-align:middle;"></td>
    </tr>
  </table>

  <!-- BLUE BANNER — shows THIS payment's amount -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:10px; background-color:#1740a8;">
    <tr>
      <td style="padding:14px 20px; vertical-align:bottom;">
        <div style="font-size:22px; font-weight:bold; color:#ffffff; letter-spacing:1.5px;">PAYMENT RECEIPT</div>
      </td>
      <td style="padding:14px 20px; text-align:right; vertical-align:bottom;">
        <div style="font-size:8px; color:#b8ccf0; letter-spacing:0.5px; margin-bottom:2px;">Amount Paid</div>
        <div style="font-size:20px; font-weight:bold; color:#ffffff;">
          &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
            <apex:param value="{!latestPayment.Amount__c}"/>
          </apex:outputText>
        </div>
      </td>
    </tr>
  </table>

  <!-- META STRIP — Receipt No / Receipt Date / Payment Status all from THIS payment -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px; border:1px solid #d8e4f4; background-color:#f4f7fd;">
    <tr>
      <td style="padding:8px 15px; vertical-align:middle; width:33%;">
        <div style="font-size:7px; color:#555; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:2px; font-weight:bold;">Receipt No</div>
        <div style="font-size:10px; font-weight:bold; color:#111111;">{!latestPayment.Name}</div>
      </td>
      <td style="border-left:1px solid #d0daea; padding:8px 15px; vertical-align:middle; width:33%;">
        <div style="font-size:7px; color:#555; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:2px; font-weight:bold;">Receipt Date</div>
        <div style="font-size:10px; font-weight:bold; color:#111111;">
          <apex:outputText value="{0,date,dd MMM yyyy}">
            <apex:param value="{!latestPayment.Payment_Date__c}"/>
          </apex:outputText>
        </div>
      </td>
      <td style="border-left:1px solid #d0daea; padding:8px 15px; vertical-align:middle; width:34%;">
        <div style="font-size:7px; color:#555; text-transform:uppercase; letter-spacing:0.6px; margin-bottom:2px; font-weight:bold;">Payment Status</div>
        <div style="font-size:10px; font-weight:bold;">
          <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Success'}"  style="color:#1a7a1a;">{!latestPayment.Payment_Status__c}</apex:outputText>
          <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Pending'}"  style="color:#c97000;">{!latestPayment.Payment_Status__c}</apex:outputText>
          <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Failed'}"   style="color:#cc0000;">{!latestPayment.Payment_Status__c}</apex:outputText>
          <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Refunded'}" style="color:#555555;">{!latestPayment.Payment_Status__c}</apex:outputText>
        </div>
      </td>
    </tr>
  </table>

  <!-- TWO COLUMNS: ORDER + CUSTOMER -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
    <tr>

      <!-- LEFT: ORDER DETAILS -->
      <td width="50%" style="vertical-align:top; padding-right:22px;">
        <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:8px;">
          <tr>
            <td style="font-size:9px; font-weight:bold; color:#1740a8; text-transform:uppercase; letter-spacing:1px; border-bottom:2px solid #1740a8; padding-bottom:4px;">
              Order Details
            </td>
          </tr>
        </table>
        <table width="100%" border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; width:140px; font-weight:bold;">Order Number</td>
            <td style="font-size:9px; font-weight:bold; color:#111; padding:4px 0;">{!orderNumber}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold;">Payment Mode</td>
            <td style="font-size:9px; font-weight:bold; color:#111; padding:4px 0;">{!latestPayment.Payment_Mode__c}</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold;">Order Start Date</td>
            <td style="font-size:9px; color:#111; padding:4px 0;">
              <apex:outputPanel rendered="{!NOT(ISNULL(orderStartDate))}">
                <apex:outputText value="{0,date,dd MMM yyyy}">
                  <apex:param value="{!orderStartDate}"/>
                </apex:outputText>
              </apex:outputPanel>
              <apex:outputPanel rendered="{!ISNULL(orderStartDate)}">&#8212;</apex:outputPanel>
            </td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold;">Delivery Date</td>
            <td style="font-size:9px; color:#111; padding:4px 0;">
              <apex:outputPanel rendered="{!NOT(ISNULL(deliveryDate))}">
                <apex:outputText value="{0,date,dd MMM yyyy}">
                  <apex:param value="{!deliveryDate}"/>
                </apex:outputText>
              </apex:outputPanel>
              <apex:outputPanel rendered="{!ISNULL(deliveryDate)}">&#8212;</apex:outputPanel>
            </td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold;">Currency</td>
            <td style="font-size:9px; color:#111; padding:4px 0;">INR (&#8377;)</td>
          </tr>
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold; border-top:1px solid #e0e8f5;">Order Total Amount</td>
            <td style="font-size:9px; font-weight:bold; color:#111; padding:4px 0; border-top:1px solid #e0e8f5;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!orderTotalAmount}"/>
              </apex:outputText>
            </td>
          </tr>
          <!-- Amount paid BEFORE this payment -->
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold;">Amount Paid Before</td>
            <td style="font-size:9px; font-weight:bold; color:#111; padding:4px 0;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!amountPaidBeforeThis}"/>
              </apex:outputText>
            </td>
          </tr>
          <!-- This payment amount -->
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold;">This Payment</td>
            <td style="font-size:9px; font-weight:bold; color:#1a7a1a; padding:4px 0;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!latestPayment.Amount__c}"/>
              </apex:outputText>
            </td>
          </tr>
          <!-- Total paid including this -->
          <tr>
            <td style="font-size:9px; color:#333; padding:4px 0; font-weight:bold;">Total Paid</td>
            <td style="font-size:9px; font-weight:bold; color:#111; padding:4px 0;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!amountPaid}"/>
              </apex:outputText>
            </td>
          </tr>
          <!-- Balance after this payment -->
          <tr>
            <td style="font-size:9px; padding:4px 0; font-weight:bold; color:#1740a8;">Balance Due</td>
            <td style="font-size:9px; font-weight:bold; color:#1740a8; padding:4px 0;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!balanceDue}"/>
              </apex:outputText>
            </td>
          </tr>
        </table>
      </td>

      <!-- RIGHT: CUSTOMER DETAILS -->
      <td width="50%" style="vertical-align:top; padding-left:22px; border-left:1px solid #e0e8f5;">
        <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:8px;">
          <tr>
            <td style="font-size:9px; font-weight:bold; color:#1740a8; text-transform:uppercase; letter-spacing:1px; border-bottom:2px solid #1740a8; padding-bottom:4px;">
              Customer Details
            </td>
          </tr>
        </table>
        <table border="0" cellpadding="0" cellspacing="0" width="100%">
          <tr>
            <td style="font-size:12px; font-weight:bold; color:#111; padding-bottom:6px;">{!customerName}</td>
          </tr>
          <!-- Billing Address -->
          <apex:outputPanel rendered="{!NOT(ISBLANK(billingCity)) || NOT(ISBLANK(billingStreet))}">
            <tr>
              <td style="font-size:7.5px; color:#888; text-transform:uppercase; letter-spacing:0.5px; padding-top:2px; padding-bottom:2px; font-weight:bold;">Billing Address</td>
            </tr>
            <apex:outputPanel rendered="{!NOT(ISBLANK(billingStreet))}">
              <tr><td style="font-size:9px; color:#333; padding-bottom:1px;">{!billingStreet}</td></tr>
            </apex:outputPanel>
            <tr>
              <td style="font-size:9px; color:#333; padding-bottom:6px;">
                {!billingCity}<apex:outputText rendered="{!NOT(ISBLANK(billingPostalCode))}">, {!billingPostalCode}</apex:outputText><apex:outputText rendered="{!NOT(ISBLANK(billingCountry))}">, {!billingCountry}</apex:outputText>
              </td>
            </tr>
          </apex:outputPanel>
          <!-- Shipping Address -->
          <apex:outputPanel rendered="{!NOT(ISBLANK(shippingCity)) || NOT(ISBLANK(shippingStreet))}">
            <tr>
              <td style="font-size:7.5px; color:#888; text-transform:uppercase; letter-spacing:0.5px; padding-bottom:2px; font-weight:bold;">Shipping Address</td>
            </tr>
            <apex:outputPanel rendered="{!NOT(ISBLANK(shippingStreet))}">
              <tr><td style="font-size:9px; color:#333; padding-bottom:1px;">{!shippingStreet}</td></tr>
            </apex:outputPanel>
            <tr>
              <td style="font-size:9px; color:#333; padding-bottom:6px;">
                {!shippingCity}<apex:outputText rendered="{!NOT(ISBLANK(shippingPostalCode))}">, {!shippingPostalCode}</apex:outputText><apex:outputText rendered="{!NOT(ISBLANK(shippingCountry))}">, {!shippingCountry}</apex:outputText>
              </td>
            </tr>
          </apex:outputPanel>
          <apex:outputPanel rendered="{!NOT(ISBLANK(customerPhone))}">
            <tr><td style="font-size:9px; color:#333; padding-bottom:3px;">&#9742; {!customerPhone}</td></tr>
          </apex:outputPanel>
          <apex:outputPanel rendered="{!NOT(ISBLANK(customerEmail))}">
            <tr><td style="font-size:9px; color:#333; padding-bottom:3px;">&#9993; {!customerEmail}</td></tr>
          </apex:outputPanel>
        </table>
      </td>

    </tr>
  </table>

  <!-- PAYMENT BREAKDOWN — shows only THIS payment -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:6px;">
    <tr>
      <td style="font-size:12px; font-weight:bold; color:#111;">Payment Breakdown</td>
    </tr>
  </table>

  <!-- Breakdown header -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0">
    <tr>
      <td width="18%" style="background-color:#1740a8; padding:7px 8px; font-size:8px; font-weight:bold; color:#fff; text-transform:uppercase; letter-spacing:0.6px;">Payment No</td>
      <td width="15%" style="background-color:#1740a8; padding:7px 8px; font-size:8px; font-weight:bold; color:#fff; text-transform:uppercase; letter-spacing:0.6px;">Date</td>
      <td width="13%" style="background-color:#1740a8; padding:7px 8px; font-size:8px; font-weight:bold; color:#fff; text-transform:uppercase; letter-spacing:0.6px;">Method</td>
      <td width="12%" style="background-color:#1740a8; padding:7px 8px; font-size:8px; font-weight:bold; color:#fff; text-transform:uppercase; letter-spacing:0.6px;">Status</td>
      <td width="24%" style="background-color:#1740a8; padding:7px 8px; font-size:8px; font-weight:bold; color:#fff; text-transform:uppercase; letter-spacing:0.6px;">Reference</td>
      <td width="18%" style="background-color:#1740a8; padding:7px 8px; font-size:8px; font-weight:bold; color:#fff; text-transform:uppercase; letter-spacing:0.6px; text-align:right;">Amount</td>
    </tr>
  </table>

  <!-- Single payment row -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
    <tr style="background-color:#f7f9fd;">
      <td width="18%" style="padding:8px; font-size:9px; font-weight:bold; color:#111; border-bottom:1px solid #e0e8f5;">{!latestPayment.Name}</td>
      <td width="15%" style="padding:8px; font-size:9px; color:#222; border-bottom:1px solid #e0e8f5;">
        <apex:outputText value="{0,date,dd MMM yyyy}">
          <apex:param value="{!latestPayment.Payment_Date__c}"/>
        </apex:outputText>
      </td>
      <td width="13%" style="padding:8px; font-size:9px; color:#222; border-bottom:1px solid #e0e8f5;">{!latestPayment.Payment_Mode__c}</td>
      <td width="12%" style="padding:8px; font-size:9px; border-bottom:1px solid #e0e8f5;">
        <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Success'}"  style="color:#1a7a1a; font-weight:bold;">{!latestPayment.Payment_Status__c}</apex:outputText>
        <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Pending'}"  style="color:#c97000; font-weight:bold;">{!latestPayment.Payment_Status__c}</apex:outputText>
        <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Failed'}"   style="color:#cc0000; font-weight:bold;">{!latestPayment.Payment_Status__c}</apex:outputText>
        <apex:outputText rendered="{!latestPayment.Payment_Status__c == 'Refunded'}" style="color:#555555; font-weight:bold;">{!latestPayment.Payment_Status__c}</apex:outputText>
      </td>
      <td width="24%" style="padding:8px; font-size:9px; color:#333; border-bottom:1px solid #e0e8f5;">
        <apex:outputText rendered="{!latestPayment.Payment_Mode__c == 'UPI'}">{!latestPayment.UPI_Reference_Number__c}</apex:outputText>
        <apex:outputText rendered="{!latestPayment.Payment_Mode__c == 'Bank Transfer'}">{!latestPayment.Transfer_Reference_Number__c}</apex:outputText>
        <apex:outputText rendered="{!latestPayment.Payment_Mode__c == 'Cash'}">{!latestPayment.Cash_Receipt_Number__c}</apex:outputText>
        <apex:outputText rendered="{!latestPayment.Payment_Mode__c == 'Card'}">{!latestPayment.Transaction_Id__c}</apex:outputText>
        <apex:outputText rendered="{!AND(latestPayment.Payment_Mode__c != 'UPI', latestPayment.Payment_Mode__c != 'Bank Transfer', latestPayment.Payment_Mode__c != 'Cash', latestPayment.Payment_Mode__c != 'Card')}">{!latestPayment.Transaction_Id__c}</apex:outputText>
      </td>
      <td width="18%" style="padding:8px; font-size:9px; font-weight:bold; color:#111; text-align:right; border-bottom:1px solid #e0e8f5;">
        &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
          <apex:param value="{!latestPayment.Amount__c}"/>
        </apex:outputText>
      </td>
    </tr>
  </table>

  <!-- SUMMARY + SIGNATURE -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:14px;">
    <tr>
      <td width="50%" style="vertical-align:top;">&#160;</td>
      <td width="50%" style="vertical-align:top; padding-left:10px;">
        <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:12px;">
          <tr>
            <td style="padding:6px 10px; font-size:9px; color:#333; font-weight:bold;">Order Total Amount</td>
            <td style="padding:6px 10px; font-size:9px; color:#111; text-align:right; font-weight:bold;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!orderTotalAmount}"/>
              </apex:outputText>
            </td>
          </tr>
          <tr>
            <td style="padding:6px 10px; font-size:9px; color:#333; font-weight:bold; border-top:1px solid #e0e8f5;">Total Amount Paid</td>
            <td style="padding:6px 10px; font-size:9px; color:#111; text-align:right; font-weight:bold; border-top:1px solid #e0e8f5;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!amountPaid}"/>
              </apex:outputText>
            </td>
          </tr>
          <tr>
            <td style="padding:8px 10px; font-size:11px; font-weight:bold; color:#1740a8; border-top:2.5px solid #1740a8;">Balance Due</td>
            <td style="padding:8px 10px; font-size:13px; font-weight:bold; color:#1740a8; text-align:right; border-top:2.5px solid #1740a8;">
              &#8377;&#160;<apex:outputText value="{0,number,###,##0.00}">
                <apex:param value="{!balanceDue}"/>
              </apex:outputText>
            </td>
          </tr>
        </table>

        <!-- Signature box -->
        <table width="100%" border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td style="text-align:right;">
              <table border="0" cellpadding="0" cellspacing="0" align="right">
                <tr>
                  <td style="border:1px dashed #9aadcc; width:130px; height:56px; text-align:center; vertical-align:middle; padding:5px 0;">
                    <img src="{!URLFOR($Resource.ArrayMinds)}" height="24" style="display:block; margin:0 auto 3px auto;"/>
                    <div style="font-size:7px; color:#aaa; text-transform:uppercase; letter-spacing:0.5px;">Stamp / Signature</div>
                  </td>
                </tr>
                <tr>
                  <td style="padding-top:4px; text-align:right;">
                    <div style="font-size:7.5px; font-weight:bold; color:#1a3a5c; text-transform:uppercase; letter-spacing:0.6px;">Authorized Signatory</div>
                    <div style="font-size:7px; color:#555;">ARRAYMINDS</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- FOOTER INFO BOX -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom:12px;">
    <tr>
      <td style="background-color:#eef3fb; border:1px solid #ccd8ee; padding:9px 14px; font-size:9px; color:#000; line-height:1.5;">
        This is a computer-generated document and does not require a physical signature. For any discrepancies, please contact our accounts department within 24 hours of receipt. Thank you for your business.
      </td>
    </tr>
  </table>

  <!-- FOOTER BAR -->
  <table width="100%" border="0" cellpadding="0" cellspacing="0">
    <tr>
      <td style="border-top:2px solid #1740a8; padding-top:8px; text-align:center;">
        <div style="font-size:10px; font-weight:bold; color:#1a3a5c;">ARRAYMINDS</div>
        <div style="font-size:7.5px; color:#555; margin-top:2px;">Dealer Management System</div>
        <div style="font-size:7.5px; color:#1740a8; margin-top:3px;">https://www.arrayminds.com</div>
      </td>
    </tr>
  </table>

  </td></tr>
  </table>

</td></tr>
</table>

</body>
</html>
</apex:page>
